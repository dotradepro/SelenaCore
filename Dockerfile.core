FROM python:3.11-slim

WORKDIR /opt/selena-core

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libffi-dev \
    libssl-dev \
    ffmpeg \
    portaudio19-dev \
    libasound2-dev \
    libsndfile1-dev \
    libspeex-dev \
    alsa-utils \
    pulseaudio-utils \
    libvlc-dev \
    vlc-plugin-base \
    vlc-bin \
    network-manager \
    rfkill \
    iputils-ping \
    iproute2 \
    arp-scan \
    arping \
    curl \
    zstd \
    git \
    fonts-noto-color-emoji \
    && rm -rf /var/lib/apt/lists/* \
    && git config --system --add safe.directory /opt/selena-core

COPY requirements.txt .
# argostranslate transitively requires stanza → torch → nvidia-* which
# would pull ~2 GB of PyTorch + CUDA wheels on EVERY docker build. Ruinous
# on Raspberry Pi and Jetson (even Jetson's native CUDA is already on the
# host — the container doesn't need its own copy). Our translation path
# (core/translation/local_translator.py + helsinki_translator.py) only
# uses argostranslate's ctranslate2 + sentencepiece primitives — stanza
# is never imported anywhere.
#
# Fix: install argostranslate with --no-deps and hand-pick its real
# runtime deps. Skips the entire stanza/torch/CUDA chain (~1.8 GB saved).
RUN pip install --no-cache-dir --no-deps "argostranslate>=1.9.0" \
    && pip install --no-cache-dir \
        sentencepiece \
        ctranslate2 \
        sacremoses

# Main install — pip sees argostranslate already satisfied, skips it.
RUN pip install --no-cache-dir -r requirements.txt

# Defensive belt-and-braces: if a future requirements.txt bump smuggles in
# a torch dep, strip it so the image stays lean. No-op on clean builds.
RUN pip uninstall -y torch stanza triton \
       nvidia-cublas nvidia-cuda-cupti nvidia-cuda-nvrtc nvidia-cuda-runtime \
       nvidia-cudnn-cu13 nvidia-cufft nvidia-cufile nvidia-curand \
       nvidia-cusolver nvidia-cusparse nvidia-cusparselt-cu13 \
       nvidia-nccl-cu13 nvidia-nvjitlink nvidia-nvshmem-cu13 nvidia-nvtx \
       cuda-toolkit cuda-bindings cuda-pathfinder 2>/dev/null; true

# Whisper STT runs natively on host (whisper-server or faster-whisper)
# Piper TTS runs natively on host via piper-server.py
# Ollama LLM runs natively on host
RUN pip install --no-cache-dir pathvalidate

# Create data directories
RUN mkdir -p /var/lib/selena/models/piper \
             /var/lib/selena/db \
             /var/lib/selena/cache

COPY core/ ./core/
COPY system_modules/ ./system_modules/
COPY agent/ ./agent/
COPY config/ ./config/
COPY scripts/start.sh ./start.sh
RUN chmod +x ./start.sh

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    CORE_PORT=80 \
    CORE_DATA_DIR=/var/lib/selena \
    CORE_SECURE_DIR=/secure \
    CORE_LOG_LEVEL=INFO \
    LD_LIBRARY_PATH=/usr/local/cuda/lib64:${LD_LIBRARY_PATH}

EXPOSE 80 443

CMD ["/bin/bash", "/opt/selena-core/start.sh"]
