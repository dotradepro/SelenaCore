FROM python:3.11-slim

WORKDIR /opt/selena-core

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libffi-dev \
    libssl-dev \
    ffmpeg \
    portaudio19-dev \
    libasound2-dev \
    libsndfile1-dev \
    libspeex-dev \
    network-manager \
    rfkill \
    iputils-ping \
    iproute2 \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY core/ ./core/
COPY system_modules/ ./system_modules/
COPY agent/ ./agent/
COPY config/ ./config/
COPY scripts/start.sh ./start.sh
RUN chmod +x ./start.sh

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    CORE_PORT=7070 \
    CORE_DATA_DIR=/var/lib/selena \
    CORE_SECURE_DIR=/secure \
    CORE_LOG_LEVEL=INFO

EXPOSE 7070 8080

CMD ["/bin/bash", "/opt/selena-core/start.sh"]
