{
    "name": "backup-manager",
    "version": "1.0.0",
    "description": "Local USB/SD and cloud E2E backup management",
    "type": "SYSTEM",
    "ui_profile": "SETTINGS_ONLY",
    "api_version": "1.0",
    "runtime_mode": "always_on",
    "group": "backup",
    "intents": ["backup.create", "backup.restore"],
    "entities": ["backup"],
    "permissions": [
        "events.publish"
    ],
    "ui": {
        "icon": "icon.svg",
        "widget": null,
        "settings": null
    },
    "oauth": null,
    "resources": {
        "memory_mb": 64,
        "cpu": 0.1
    },
    "author": "SmartHome LK",
    "license": "MIT",
    "homepage": "https://github.com/dotradepro/SelenaCore"
}
