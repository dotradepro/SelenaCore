{
    "name": "satellite-manager",
    "version": "0.1.0",
    "room": "system",
    "description": "ESP32 satellite speaker management: BLE provisioning, WebSocket audio transport, OTA",
    "type": "SYSTEM",
    "ui_profile": "FULL",
    "api_version": "1.0",
    "runtime_mode": "always_on",
    "group": "voice",
    "intents": [],
    "entities": ["satellite_speaker"],
    "permissions": [
        "device.read",
        "device.write",
        "events.subscribe",
        "events.publish"
    ],
    "ui": {
        "icon": "icon.svg",
        "widget": {
            "kind": "template",
            "template": "metric",
            "size": "2x1",
            "max_size": "2x2",
            "data_endpoints": {
                "state": {"path": "/widget/data/state", "cache_ttl_s": 30}
            },
            "refresh": {
                "events": ["device.online", "device.offline"],
                "poll_interval_s": 60
            }
        },
        "settings": "settings.html"
    },
    "resources": {
        "memory_mb": 128,
        "cpu": 0.2
    },
    "author": "SmartHome LK",
    "license": "MIT",
    "homepage": "https://github.com/dotradepro/SelenaCore"
}
