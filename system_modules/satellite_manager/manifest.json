{
    "name": "satellite-manager",
    "version": "0.1.0",
    "description": "ESP32 satellite speaker management: BLE provisioning, WebSocket audio transport, OTA",
    "type": "SYSTEM",
    "ui_profile": "FULL",
    "api_version": "1.0",
    "runtime_mode": "always_on",
    "group": "voice",
    "intents": [],
    "entities": ["satellite_speaker"],
    "permissions": [
        "device.read",
        "device.write",
        "events.subscribe",
        "events.publish"
    ],
    "ui": {
        "icon": "icon.svg",
        "widget": {
            "file": "widget.html",
            "size": "1x1",
            "min_size": "1x1",
            "max_size": "1x1"
        },
        "settings": "settings.html"
    },
    "resources": {
        "memory_mb": 128,
        "cpu": 0.2
    },
    "author": "SmartHome LK",
    "license": "MIT",
    "homepage": "https://github.com/dotradepro/SelenaCore"
}
