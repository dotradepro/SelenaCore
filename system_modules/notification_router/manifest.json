{
    "name": "notification-router",
    "version": "1.0.0",
    "room": "system",
    "description": "Routes notifications to channels: TTS voice, Telegram, Web Push, HTTP webhook",
    "type": "SYSTEM",
    "ui_profile": "FULL",
    "api_version": "1.0",
    "runtime_mode": "always_on",
    "group": "notification",
    "intents": ["notification.send", "notification.list"],
    "entities": ["notification", "alert"],
    "permissions": [
        "events.subscribe",
        "events.publish"
    ],
    "ui": {
        "icon": "icon.svg",
        "widget": {
            "kind": "template",
            "template": "status",
            "size": "2x2",
            "max_size": "4x2",
            "data_endpoints": {
                "state": {"path": "/widget/data/state", "cache_ttl_s": 15}
            },
            "refresh": {
                "events": ["notification.sent"],
                "poll_interval_s": 60
            }
        },
        "settings": "settings.html"
    },
    "oauth": null,
    "resources": {
        "memory_mb": 64,
        "cpu": 0.1
    },
    "author": "SmartHome LK",
    "license": "MIT",
    "homepage": "https://github.com/dotradepro/SelenaCore"
}
