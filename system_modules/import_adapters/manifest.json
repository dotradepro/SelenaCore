{
    "name": "import-adapters",
    "version": "1.0.0",
    "description": "Import devices from Home Assistant, Tuya and Philips Hue into SelenaCore Device Registry",
    "type": "SYSTEM",
    "ui_profile": "SETTINGS_ONLY",
    "api_version": "1.0",
    "runtime_mode": "on_demand",
    "group": "system",
    "intents": ["import.scan", "import.start"],
    "entities": ["import", "adapter"],
    "permissions": [
        "device.write",
        "events.publish"
    ],
    "ui": {
        "icon": "icon.svg",
        "settings": "settings.html"
    },
    "oauth": null,
    "resources": {
        "memory_mb": 64,
        "cpu": 0.1
    },
    "author": "SmartHome LK",
    "license": "MIT",
    "homepage": "https://github.com/dotradepro/SelenaCore"
}