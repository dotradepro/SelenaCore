{
    "name": "presence-detection",
    "version": "0.1.0",
    "room": "system",
    "description": "Detects home/away presence via ARP ping, Bluetooth, and Wi-Fi MAC tracking",
    "type": "SYSTEM",
    "ui_profile": "FULL",
    "api_version": "1.0",
    "runtime_mode": "always_on",
    "group": "presence",
    "intents": ["presence.query"],
    "entities": ["presence", "home", "person"],
    "permissions": [
        "device.read",
        "events.subscribe",
        "events.publish"
    ],
    "ui": {
        "icon": "icon.svg",
        "widget": {
            "kind": "template",
            "template": "status",
            "size": "2x2",
            "max_size": "4x2",
            "data_endpoints": {
                "state": {"path": "/widget/data/state", "cache_ttl_s": 15}
            },
            "refresh": {
                "events": ["presence.home", "presence.away"],
                "poll_interval_s": 60
            }
        }
    },
    "oauth": null,
    "resources": {
        "memory_mb": 128,
        "cpu": 0.25
    },
    "author": "SmartHome LK",
    "license": "MIT",
    "homepage": "https://github.com/dotradepro/SelenaCore"
}