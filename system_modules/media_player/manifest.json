{
    "name": "media-player",
    "version": "0.1.0",
    "room": "home",
    "description": "Media player: internet radio, USB, SMB, Internet Archive. Voice control, cover art.",
    "type": "SYSTEM",
    "ui_profile": "FULL",
    "api_version": "1.0",
    "runtime_mode": "always_on",
    "group": "media",
    "intents": ["media.play", "media.stop", "media.pause", "media.resume", "media.volume_set", "media.next", "media.prev"],
    "entities": ["radio", "music", "audio", "track", "playlist"],
    "permissions": [
        "events.subscribe",
        "events.publish"
    ],
    "ui": {
        "icon": "icon.svg",
        "widget": {
            "kind": "template",
            "template": "media",
            "size": "4x2",
            "max_size": "4x2",
            "data_endpoints": {
                "state": {"path": "/widget/data/state", "cache_ttl_s": 5}
            },
            "actions": {
                "set_mode": {"path": "/widget/action/set_mode"},
                "step": {"path": "/widget/action/step"}
            },
            "refresh": {
                "poll_interval_s": 10
            }
        },
        "settings": "settings.html"
    },
    "resources": {
        "memory_mb": 128,
        "cpu": 0.5
    },
    "author": "SelenaCore Community",
    "license": "MIT"
}
