{
  "name": "weather-service",
  "version": "1.0.0",
  "description": "Local weather conditions and forecast via Open-Meteo (no API key required)",
  "type": "UI",
  "ui_profile": "FULL",
  "api_version": "1.0",
  "runtime_mode": "always_on",
  "port": 8115,
  "permissions": [
    "events.publish"
  ],
  "ui": {
    "icon": "icon.svg",
    "widget": {
      "file": "widget.html",
      "size": "2x2"
    },
    "settings": "settings.html"
  },
  "oauth": null,
  "resources": {
    "memory_mb": 64,
    "cpu": 0.1
  },
  "author": "SmartHome LK",
  "license": "MIT",
  "homepage": "https://github.com/dotradepro/SelenaCore"
}
