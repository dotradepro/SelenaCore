{
    "name": "weather-service",
    "version": "1.0.0",
    "description": "Local weather conditions and forecast via Open-Meteo (no API key required)",
    "type": "SYSTEM",
    "ui_profile": "FULL",
    "api_version": "1.0",
    "runtime_mode": "always_on",
    "group": "weather",
    "intents": ["weather.query"],
    "entities": ["weather", "forecast", "temperature"],
    "permissions": [
        "events.publish"
    ],
    "ui": {
        "icon": "icon.svg",
        "widget": {
            "file": "widget.html",
            "size": "2x2",
            "max_size": "3x3"
        },
        "settings": "settings.html"
    },
    "oauth": null,
    "resources": {
        "memory_mb": 64,
        "cpu": 0.1
    },
    "author": "SmartHome LK",
    "license": "MIT",
    "homepage": "https://github.com/dotradepro/SelenaCore"
}
