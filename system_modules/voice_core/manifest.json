{
    "name": "voice-core",
    "version": "1.0.0",
    "room": "system",
    "description": "Voice subsystem: STT (Vosk), TTS (Piper), wake word detection, speaker ID, privacy mode",
    "type": "SYSTEM",
    "ui_profile": "FULL",
    "api_version": "1.0",
    "runtime_mode": "always_on",
    "group": "voice",
    "intents": ["voice.privacy_on", "voice.privacy_off", "voice.status"],
    "entities": ["voice", "microphone"],
    "permissions": [
        "device.read",
        "events.subscribe",
        "events.publish"
    ],
    "ui": {
        "icon": "icon.svg",
        "widget": {
            "kind": "template",
            "template": "status",
            "size": "2x2",
            "max_size": "4x2",
            "data_endpoints": {
                "state": {"path": "/widget/data/state", "cache_ttl_s": 5}
            },
            "refresh": {
                "events": ["voice.state", "voice.privacy_on", "voice.privacy_off"],
                "poll_interval_s": 30
            }
        },
        "settings": "settings.html"
    },
    "oauth": null,
    "resources": {
        "memory_mb": 256,
        "cpu": 0.5
    },
    "author": "SmartHome LK",
    "license": "MIT",
    "homepage": "https://github.com/dotradepro/SelenaCore"
}
