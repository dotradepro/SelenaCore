{
    "name": "voice-core",
    "version": "1.0.0",
    "description": "Voice subsystem: STT (Vosk), TTS (Piper), wake word detection, speaker ID, privacy mode",
    "type": "SYSTEM",
    "ui_profile": "FULL",
    "api_version": "1.0",
    "runtime_mode": "always_on",
    "group": "voice",
    "intents": ["voice.privacy_on", "voice.privacy_off", "voice.status"],
    "entities": ["voice", "microphone"],
    "permissions": [
        "device.read",
        "events.subscribe",
        "events.publish"
    ],
    "ui": {
        "icon": "icon.svg",
        "widget": {
            "file": "widget.html",
            "size": "2x2",
            "max_size": "2x2"
        },
        "settings": "settings.html"
    },
    "oauth": null,
    "resources": {
        "memory_mb": 256,
        "cpu": 0.5
    },
    "author": "SmartHome LK",
    "license": "MIT",
    "homepage": "https://github.com/dotradepro/SelenaCore"
}
