{
    "name": "automation-engine",
    "version": "0.1.0",
    "description": "YAML-based rule engine — triggers (time/event/device/presence) → actions (commands, scenes, notifications)",
    "type": "SYSTEM",
    "ui_profile": "FULL",
    "api_version": "1.0",
    "runtime_mode": "always_on",
    "port": 8108,
    "permissions": [
        "device.read",
        "device.write",
        "events.subscribe",
        "events.publish"
    ],
    "ui": {
        "icon": "icon.svg",
        "widget": {
            "file": "widget.html",
            "size": "2x1"
        },
        "settings": "settings.html"
    },
    "oauth": null,
    "resources": {
        "memory_mb": 128,
        "cpu": 0.25
    },
    "author": "SmartHome LK",
    "license": "MIT",
    "homepage": "https://github.com/dotradepro/SelenaCore"
}