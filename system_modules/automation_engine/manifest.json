{
    "name": "automation-engine",
    "version": "0.1.0",
    "room": "system",
    "description": "YAML-based rule engine — triggers (time/event/device/presence) → actions (commands, scenes, notifications)",
    "type": "SYSTEM",
    "ui_profile": "FULL",
    "api_version": "1.0",
    "runtime_mode": "always_on",
    "group": "automation",
    "intents": ["automation.run", "automation.list"],
    "entities": ["automation", "rule", "scene"],
    "permissions": [
        "device.read",
        "device.write",
        "events.subscribe",
        "events.publish"
    ],
    "ui": {
        "icon": "icon.svg",
        "widget": {
            "kind": "template",
            "template": "metric",
            "size": "2x1",
            "max_size": "2x2",
            "data_endpoints": {
                "state": {"path": "/widget/data/state", "cache_ttl_s": 30}
            },
            "refresh": {
                "events": ["scene.activated", "scene.failed"],
                "poll_interval_s": 60
            }
        },
        "settings": "settings.html"
    },
    "oauth": null,
    "resources": {
        "memory_mb": 128,
        "cpu": 0.25
    },
    "author": "SmartHome LK",
    "license": "MIT",
    "homepage": "https://github.com/dotradepro/SelenaCore"
}
