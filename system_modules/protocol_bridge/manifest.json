{
    "name": "protocol-bridge",
    "version": "0.1.0",
    "room": "system",
    "description": "Protocol gateway: MQTT/Zigbee/Z-Wave/HTTP ↔ Device Registry",
    "type": "SYSTEM",
    "ui_profile": "FULL",
    "api_version": "1.0",
    "runtime_mode": "always_on",
    "group": "network",
    "intents": ["protocol.status"],
    "entities": ["bridge", "protocol", "gateway"],
    "permissions": [
        "device.read",
        "device.write",
        "events.subscribe",
        "events.publish"
    ],
    "ui": {
        "icon": "icon.svg",
        "widget": {
            "kind": "template",
            "template": "status",
            "size": "2x2",
            "max_size": "4x2",
            "data_endpoints": {
                "state": {"path": "/widget/data/state", "cache_ttl_s": 30}
            },
            "refresh": {
                "poll_interval_s": 60
            }
        },
        "settings": "settings.html"
    },
    "resources": {
        "memory_mb": 256,
        "cpu": 0.25
    },
    "author": "SmartHome LK",
    "license": "MIT",
    "homepage": "https://github.com/dotradepro/SelenaCore"
}
