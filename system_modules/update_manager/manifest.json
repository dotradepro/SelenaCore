{
    "name": "update-manager",
    "version": "1.1.0",
    "room": "system",
    "description": "OTA update management: GitHub Releases as source of truth, mandatory SHA256 verification, version history UI, rollback via external script under systemd-run (ReadOnlyPaths-safe)",
    "type": "SYSTEM",
    "ui_profile": "FULL",
    "api_version": "1.0",
    "runtime_mode": "always_on",
    "group": "system",
    "intents": ["update.check", "update.install"],
    "entities": ["update", "firmware"],
    "permissions": [
        "events.publish"
    ],
    "ui": {
        "icon": "icon.svg",
        "widget": {
            "kind": "template",
            "template": "status",
            "size": "2x2",
            "max_size": "4x2",
            "data_endpoints": {
                "state": {"path": "/widget/data/state", "cache_ttl_s": 60}
            },
            "refresh": {
                "poll_interval_s": 300
            }
        },
        "settings": "settings.html"
    },
    "oauth": null,
    "resources": {
        "memory_mb": 96,
        "cpu": 0.1
    },
    "author": "SmartHome LK",
    "license": "MIT",
    "homepage": "https://github.com/dotradepro/SelenaCore"
}
