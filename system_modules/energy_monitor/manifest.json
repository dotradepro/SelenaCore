{
    "name": "energy-monitor",
    "version": "1.0.0",
    "description": "Per-device power consumption tracking, daily kWh reports, and anomaly detection",
    "type": "SYSTEM",
    "ui_profile": "FULL",
    "api_version": "1.0",
    "runtime_mode": "always_on",
    "permissions": [
        "device.read",
        "events.subscribe",
        "events.publish"
    ],
    "ui": {
        "icon": "icon.svg",
        "widget": {
            "file": "widget.html",
            "size": "2x2",
            "max_size": "3x3"
        },
        "settings": "settings.html"
    },
    "oauth": null,
    "resources": {
        "memory_mb": 96,
        "cpu": 0.1
    },
    "author": "SmartHome LK",
    "license": "MIT",
    "homepage": "https://github.com/dotradepro/SelenaCore"
}
