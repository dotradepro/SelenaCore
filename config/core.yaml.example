# SelenaCore — конфигурация ядра
version: "0.3.0-beta"

core:
  host: "0.0.0.0"
  port: 7070
  data_dir: "/var/lib/selena"
  secure_dir: "/secure"
  log_level: "INFO"
  debug: false

ui:
  host: "0.0.0.0"
  port: 80
  https: true

agent:
  check_interval_sec: 30
  max_restore_attempts: 3
  core_files_glob: "/opt/selena-core/core/**/*.py"
  manifest_path: "/secure/core.manifest"
  master_hash_path: "/secure/master.hash"
  backup_dir: "/secure/core_backup/v0.3.0/"
  log_path: "/var/log/selena/integrity.log"

modules:
  container_image: "smarthome-modules:latest"
  sandbox_image: "smarthome-sandbox:latest"

voice:
  wake_word_sensitivity: 0.5
  stt_model: "base"                    # tiny | base | small | medium
  stt_silence_timeout: 1.0            # seconds of silence before processing (0.5-5.0)
  tts_voice: "uk_UA-ukrainian_tts-medium"
  rephrase_enabled: false              # LLM rephrase for module responses (adds latency)
  tts_settings:
    length_scale: 1.0                  # speech speed (0.5=fast, 2.0=slow)
    noise_scale: 0.667                 # intonation variability (0.0-1.0)
    noise_w_scale: 0.8                 # phoneme width variability (0.0-1.0)
    sentence_silence: 0.2             # pause between sentences (sec)
    volume: 1.0                        # volume (0.1-3.0)
    speaker: 0                         # speaker ID for multi-speaker models
  audio_force_input: null
  audio_force_output: null
  privacy_gpio_pin: null

llm:
  enabled: true
  provider: "ollama"
  ollama_url: "http://localhost:11434"
  default_model: "phi-3-mini"
  min_ram_gb: 5
  timeout_sec: 30
  llm_two_step: false              # two-step LLM: classify noun_class → extract intent (faster)

platform:
  api_url: "https://smarthome-lk.com/api/v1"
  device_hash: ""
  heartbeat_interval_sec: 60
  mock: false

wizard:
  completed: false
  current_step: null

system:
  device_name: "SelenaCore"
  language: "ru"
  timezone: "Europe/Moscow"
  initialized: false
