# SelenaCore — конфигурация ядра
version: "0.3.0-beta"

core:
  host: "0.0.0.0"
  port: 80
  data_dir: "/var/lib/selena"
  secure_dir: "/secure"
  log_level: "INFO"
  debug: false

ui:
  host: "0.0.0.0"
  port: 80
  https: true

agent:
  check_interval_sec: 30
  max_restore_attempts: 3
  core_files_glob: "/opt/selena-core/core/**/*.py"
  manifest_path: "/secure/core.manifest"
  master_hash_path: "/secure/master.hash"
  backup_dir: "/secure/core_backup/v0.3.0/"
  log_path: "/var/log/selena/integrity.log"

modules:
  container_image: "smarthome-modules:latest"
  sandbox_image: "smarthome-sandbox:latest"

stt:
  provider: "vosk"                     # vosk | auto
  vosk:
    models_dir: "/var/lib/selena/models/vosk"
    active_model: ""                   # auto-detected from models_dir if empty
  whisper:
    models_dir: "/var/lib/selena/models/whisper"
    active_model: ""                   # e.g. ggml-base.bin

voice:
  wake_word_sensitivity: 0.5
  stt_silence_timeout: 1.0            # seconds of silence before processing (0.5-5.0)
  rephrase_enabled: false              # LLM rephrase for module responses (adds latency)
  speaker_id:
    embeddings_dir: "/var/lib/selena/speaker_embeddings"
    similarity_threshold: 0.75
  tts:
    models_dir: "/var/lib/selena/models/piper"
    server_url: "http://localhost:5100"
    primary:
      voice: "uk_UA-ukrainian_tts-medium"
      lang: "uk"
      cuda: true                        # GPU acceleration (Jetson/CUDA)
      settings:
        length_scale: 1.0
        noise_scale: 0.667
        noise_w_scale: 0.8
        volume: 1.0
        speaker: 0
    fallback:
      voice: "en_US-ryan-low"
      lang: "en"
      cuda: false                       # CPU for fallback (saves GPU RAM)
      settings:
        length_scale: 1.0
        noise_scale: 0.667
        noise_w_scale: 0.8
        volume: 1.0
        speaker: 0
  audio_force_input: null
  audio_force_output: null
  privacy_gpio_pin: null

ai:
  conversation:
    provider: "local"                  # local | cloud
    local:
      host: "http://localhost:11434"
      model: "qwen2.5:3b"
      options:
        temperature: 0.1
        num_predict: 80
    cloud:
      url: ""                          # https://api.groq.com/openai/v1
      key: ""                          # or set GROQ_API_KEY env var
      model: "llama-3.1-8b-instant"

llm:
  enabled: true
  provider: "ollama"
  ollama_url: "http://localhost:11434"
  default_model: "phi-3-mini"
  min_ram_gb: 5
  timeout_sec: 30
  llm_two_step: false              # two-step LLM: classify noun_class → extract intent (faster)

platform:
  api_url: "https://selenehome.tech/api/v1"
  device_hash: ""
  heartbeat_interval_sec: 60
  mock: false

wizard:
  completed: false
  current_step: null

intent:
  # Tier 1 of IntentRouter.route(): sentence-transformers cosine over
  # the per-utterance filtered catalog. Confident hits short-circuit
  # the Local LLM tier (~60× faster, ~22 MB model footprint vs ~1 GB
  # for qwen 1.5b). Falls through to LLM when score or margin is too
  # low to trust. See system_modules/llm_engine/embedding_classifier.py.
  embedding_enabled: true
  # Cosine score threshold below which we fall through to LLM. Tuned
  # against the 40-case trace bench: anchors are normalized so 0.30
  # cleanly separates "definitely something" from "weird input".
  embedding_score_threshold: 0.30
  # Margin (winner_score - runner_up_score) threshold. Below this
  # the top-2 are too close to trust the embedding pick alone, fall
  # through to LLM for disambiguation.
  embedding_margin_threshold: 0.05
  # When true, unrecognised commands are forwarded to the LLM for a
  # freeform conversational reply instead of the static "I did not
  # understand" fallback. Ollama is available on all devices (Pi and
  # Jetson). Disable to save LLM resources (embedding-only mode with
  # deterministic fallback).
  llm_assistant_enabled: true

translation:
  enabled: false
  # Engine: argos | helsinki
  #   argos    — Argos Translate (.argosmodel packages, default)
  #   helsinki — Helsinki-NLP/opus-mt via CTranslate2 (better quality
  #              on most pairs, especially en→target). Requires
  #              pre-converted models on disk under input_model_dir /
  #              output_model_dir; see docs/helsinki-translator.md.
  # Each /translate/activate call rewrites this key explicitly so the
  # currently-active row in the UI always pins both lang AND engine.
  engine: argos
  active_lang: ""
  fallback_to_llm: true
  spell_correction: false
  # Model dirs are HELSINKI-only. Each holds one subfolder per language
  # pair (e.g. uk-en/, en-uk/) containing model.bin + source.spm +
  # target.spm. Argos manages its own storage under
  # ~/.local/share/argos-translate/packages/ and ignores these keys.
  input_model_dir: /var/lib/selena/models/translate/helsinki/in
  output_model_dir: /var/lib/selena/models/translate/helsinki/out

system:
  device_name: "SelenaCore"
  language: "ru"
  timezone: "Europe/Moscow"
  initialized: false
